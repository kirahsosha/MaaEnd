//这块代码的目的是通过追踪标记来识别农田，并点击追踪标记
//节点从Start进入，开始前必须要在农田附近
//节点从Exit离开，这里关联下一个阶段的节点
{
    //节点出入口
    "_AutoEcoFindFarmFarmlandValleyStart": {
        "desc": "通过追踪标记来识别四号谷地的农田，并点击追踪标记",
        "next": [
            "[JumpBack]_AutoEcoFarmFindValleyIVEcoFarmValleyIV",
            "_AutoEcoFindFarmFarmlandValleyIVExit"
        ]
    },
    "_AutoEcoFindFarmFarmlandWulinStart": {
        "desc": "通过追踪标记来识别武陵的农田，并点击追踪标记",
        "next": [
            "[JumpBack]_AutoEcoFarmFindValleyIVEcoFarmWulin",
            "_AutoEcoFindFarmFarmlandWulinExit"
        ]
    },
    "_AutoEcoFindFarmFarmlandValleyIVExit": {
        "next": [
            "_AutoEcoFarmSwipeToTargetValleyIVStart"
        ]
    },
    "_AutoEcoFindFarmFarmlandWulinExit": {
        "next": [
            "_AutoEcoFarmSwipeToTargetWulinStart"
        ]
    },
    //内部节点
    "_AutoEcoFarmFindValleyIVEcoFarmValleyIV": {
        "desc": "[四号谷地版]任务主体",
        "max_hit": 1,
        "next": [
            "_AutoEcoFarmFindValleyIVEcoFarm",
            "[JumpBack]SceneEnterMapValleyIVOriginiumSciencePark"
        ]
    },
    "_AutoEcoFarmFindValleyIVEcoFarmWulin": {
        "desc": "[武陵版]任务主体",
        "max_hit": 1,
        "next": [
            "_AutoEcoFarmFindWulinEcoFarm",
            "[JumpBack]SceneEnterMapWulingWulingCity"
        ]
    },
    "_AutoEcoFarmFindValleyIVEcoFarmAny": {
        "desc": "[当前地图版]任务主体，用于循环任务,默认关闭",
        "enabled": false,
        "max_hit": 3,
        "next": [
            "_AutoEcoFarmInMap",
            "[JumpBack]SceneEnterMapAny"
        ]
    },
    "_AutoEcoFarmInMap": {
        "desc": "查找标记管理按钮来确认是否在地图界面",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    25,
                    635,
                    156,
                    48
                ],
                "expected": [
                    "标记|显示|管理"
                ]
            }
        },
        "next": [
            //两个版本都试试
            "_AutoEcoFarmFindValleyIVEcoFarm",
            "_AutoEcoFarmFindWulinEcoFarm"
        ]
    },
    "_AutoEcoFarmFindValleyIVEcoFarm": {
        "desc": "寻找源石研究园的生态种植这几个字,找到后将鼠标移到目标位置并滚动视角直到最大",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    649,
                    225,
                    515,
                    399
                ],
                "expected": "生|态|种|植",
                "threshold": 0.7
            }
        },
        "action": {
            "type": "Scroll",
            "param": {
                "target": true,
                "dy": 720
            }
        },
        "next": [
            //找到农田就下一步，没找到再拉缩放
            "_AutoEcoFarmFindFarmland",
            //通过一个自循环来做到多次识别→拉近
            "_AutoEcoFarmPullValleyIVEcoFarmToCenter",
            //不行的话尝试筛选标记
            "[JumpBack]_AutoEcoFarmClickTargetManager",
            //要是一直失败就先移动鼠标避免干扰再找
            "[JumpBack]_AutoEcoFarmMoveMouse"
        ]
    },
    "_AutoEcoFarmFindWulinEcoFarm": {
        "desc": "寻找武陵城的“实验作物试点”这几个字,找到后将鼠标移到目标位置并滚动视角直到最大",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    237,
                    98,
                    671,
                    373
                ],
                "expected": "作|物|试|点",
                "threshold": 0.7
            }
        },
        "action": {
            "type": "Scroll",
            "param": {
                "target": true,
                "dy": 720
            }
        },
        "next": [
            //找到农田就下一步，没找到再拉缩放
            "_AutoEcoFarmFindFarmland",
            //通过一个自循环来做到多次识别→拉近
            "_AutoEcoFarmPullWulinEcoFarmToCenter",
            //不行的话尝试筛选标记
            "[JumpBack]_AutoEcoFarmClickTargetManager",
            //要是一直失败就先移动鼠标避免干扰再找
            "[JumpBack]_AutoEcoFarmMoveMouse"
        ]
    },
    "_AutoEcoFarmPullValleyIVEcoFarmToCenter": {
        "desc": "将生态园拉到屏幕中间",
        "max_hit": 10,
        "action": {
            "type": "Swipe",
            "param": {
                "begin": "_AutoEcoFarmFindValleyIVEcoFarm",
                "end": [
                    640,
                    360,
                    1,
                    1
                ]
            }
        },
        "post_wait_freezes": 200,
        "next": [
            "_AutoEcoFarmFindValleyIVEcoFarm"
        ]
    },
    "_AutoEcoFarmPullWulinEcoFarmToCenter": {
        "desc": "将“实验作物试点”拉到屏幕中间",
        "max_hit": 10,
        "action": {
            "type": "Swipe",
            "param": {
                "begin": "_AutoEcoFarmFindWulinEcoFarm",
                "end": [
                    640,
                    360,
                    1,
                    1
                ]
            }
        },
        "post_wait_freezes": 200,
        "next": [
            "_AutoEcoFarmFindWulinEcoFarm"
        ]
    },
    "_AutoEcoFarmFindFarmland": {
        "desc": "全屏寻找农田,识别到了后点击",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    1280,
                    720
                ],
                "template": "AutoEcoFarm/AutoEcoFarmFarmland.png",
                "order_by": "Horizontal"
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "_AutoEcoFarmIsMrarking",
            "[JumpBack]_AutoEcoFarmMutiSelection",
            "_AutoEcoFarmAlreadySetTarget",
            "_AutoEcoFarmSetTarget",
            "[JumpBack]_AutoEcoFarmMoveMouse"
            //识别不到农田的话不结束脚本，而是只结束该子任务，因为农田可能就在边上
            //这里结束，触发Jumpback
        ]
    },
    "_AutoEcoFarmIsMrarking": {
        "desc": "找到标记两个字说明点歪了，按一下esc",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    937,
                    33,
                    281,
                    45
                ],
                "expected": [
                    "标记"
                ],
                "threshold": 0.7
            }
        },
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 27 //esc键
            }
        },
        "next": [
            "_AutoEcoFarmFindFarmland"
        ]
    },
    "_AutoEcoFarmAlreadySetTarget": {
        "desc": "找到取消两个字则直接下一步，不点击",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1123,
                    644,
                    113,
                    35
                ],
                "expected": [
                    "取消"
                ],
                "threshold": 0.9
            }
        },
        "next": [
            //这里结束，触发Jumpback
        ]
    },
    "_AutoEcoFarmSetTarget": {
        "desc": "点击追踪按钮，设定追踪",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1123,
                    644,
                    113,
                    35
                ],
                "expected": [
                    "追踪"
                ],
                "threshold": 0.9
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            //这里结束，触发Jumpback
        ]
    },
    "_AutoEcoFarmMutiSelection": {
        "desc": "识别是否有多选情况，识别初次点击点附近有无田块字样，有的话点一下含田块两字的选项",
        "max_hit": 3, //超过3次没点掉就是出bug了直接跳过
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    873,
                    361,
                    273,
                    262
                ],
                "expected": "田块"
            }
        },
        "action": {
            "type": "Click"
        }
    }
}
