{
    "GrowthChamber": {
        "doc": "[控制中枢·培养舱] 识别培养舱界面，领取奖励和再次培养",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    43,
                    0,
                    96,
                    64
                ],
                "expected": [
                    "培养舱"
                ]
            }
        },
        "focus": {
            "Node.PipelineNode.Failed": "培养舱奖励或再次培养流程失败"
        },
        "next": [
            "[JumpBack]Grow",
            "[JumpBack]YellowConfirmButtonType1",
            "[JumpBack]CloseRewardsButton",
            "ExitGrowthChamber"
        ]
    },
    "SelectGrowTarget": {
        "doc": "选择培养目标",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    80,
                    200,
                    301,
                    383
                ],
                "expected": [
                    "菌",
                    "石",
                    "叶"
                ]
            }
        }
    },
    "SelectGrow": {
        "doc": "选择培养目标",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "SelectGrowTarget"
                    //"CheckGrowTargetEmpty"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "[JumpBack]WhiteConfirmButtonType1",
            "ExtractSeed",
            "ExitGrow",
            "InGrowthChamber"
        ]
    },
    "CheckGrowTargetEmpty": {
        "doc": "检查选择的培养对象是否为空",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": "SelectGrowTarget",
                "roi_offset": [
                    31,
                    41,
                    23,
                    0
                ],
                "only_rec": true,
                "expected": [
                    "^([1-9][0-9]*)([/|\\]]).*$"
                ]
            }
        }
    },
    "InGrowthChamber": {
        "doc": "已经回到培养舱界面,任务完成",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    941,
                    0,
                    339,
                    113
                ],
                "expected": [
                    "生产助力"
                ]
            }
        }
    },
    "ExitGrow": {
        "doc": "不需要提取基核,直接退出培养界面",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    747,
                    481,
                    350,
                    205
                ],
                "expected": [
                    "前往提取基核"
                ]
            }
        },
        "next": [
            "GrayCancelButton"
        ]
    },
    "ExtractSeed": {
        "doc": "提取基核",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    747,
                    481,
                    350,
                    205
                ],
                "expected": [
                    "前往提取基核"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "[JumpBack]WhiteConfirmButtonType2",
            "GrowCloseRewardsButton",
            "NoMaterials"
        ]
    },
    "GrowCloseRewardsButton": {
        "doc": "培养舱界面特殊关闭，关闭奖励通知后会跟随关闭一个灰色取消按钮",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "Common/Button/CloseRewardButton.png",
                    "Common/Button/CloseRewardButtonHover.png"
                ],
                "roi": [
                    571,
                    594,
                    139,
                    126
                ],
                "threshold": 0.9
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "GrayCancelButton"
        ]
    },
    "NoMaterials": {
        "doc": "缺少原料无法获取",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    640,
                    464,
                    368,
                    143
                ],
                "expected": [
                    "缺少原料",
                    "无法获取"
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "contact": 1
            }
        },
        "next": [
            "FinishAllDijiangTask"
        ]
    },
    "InSelectGrowSwipe": {
        "doc": "在选择培养对象界面滑动",
        "max_hit": 50,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    0,
                    296,
                    111
                ],
                "expected": [
                    "选择培养对象"
                ]
            }
        },
        "action": {
            "type": "Scroll",
            "param": {
                "dx": 120,
                "target": [
                    231,
                    381
                ]
            }
        }
    },
    "Grow": {
        "doc": "点击培养按钮",
        "post_wait_freezes": {
            "time": 150,
            "timeout": 2000
        },
        "max_hit": 1,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    484,
                    213,
                    726,
                    283
                ],
                "expected": [
                    "^培养$"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "InGrow"
        ]
    },
    "InGrow": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    0,
                    296,
                    111
                ],
                "expected": [
                    "选择培养对象"
                ]
            }
        },
        "next": [
            "[JumpBack]SortBy",
            "[JumpBack]SortOrder",
            "[JumpBack]SelectGrow",
            "[JumpBack]InSelectGrowSwipe",
            "InGrowthChamber"
        ]
    },
    "SortBy": {
        "doc": "排序,选择基础排序内容",
