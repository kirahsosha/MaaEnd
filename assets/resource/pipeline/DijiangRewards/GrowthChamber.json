                    111
                ],
                "expected": [
                    "默认",
                    "基核数量",
                    "品质",
                    "預設",
                    "基核數量",
                    "品質",
                    "デフォルト",
                    "基核数",
                    "品質",
                    "Default",
                    "Amount of Seeds",
                    "Quality"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "ChooseSortBy",
            "[JumpBack]SwipeChooseSortBy"
        ]
    },
    "ChooseSortBy": {
        "doc": "选择具体排序方式",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    59,
                    343,
