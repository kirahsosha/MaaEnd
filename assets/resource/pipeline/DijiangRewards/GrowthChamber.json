        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    59,
                    343,
                    287,
                    291
                ],
                "expected": [
                    "默认",
                    "拥有数量",
                    "基核数量",
                    "品质"
                ]
            }
        },
        "action": {
            "type": "Scroll",
            "param": {
                "dx": 120
            }
        }
    },
    "SortOrder": {
        "doc": "排序,选择正序或者倒序",
        "enabled": false,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    246,
                    500,
