        }
    },
    "ExitGrowthChamber": {
        "doc": "[培养舱·离开] 返回控制中枢",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    43,
                    0,
                    96,
                    64
                ],
                "expected": [
                    "培养舱"
                ]
